model Orders {
    id               String      @id @default(uuid())
    user_id          String
    provider_id      String
    status           OrderStatus @default(PREPARING)
    total_price      Decimal     @db.Decimal(10, 2)
    delivery_address String
    created_at       DateTime    @default(now())
    updated_at       DateTime    @updatedAt

    @@index([user_id])
    @@index([provider_id])
    @@map("orders")
}

enum OrderStatus {
    PLACED
    PREPARING
    READY
    DELIVERED
    CANCELLED
}
